# Banco de dados para TESTES
# IMPORTANTE: Use um banco SEPARADO do desenvolvimento/produção!
# Vários testes fazem DROP SCHEMA e apagam todos os dados.
#
# Opções:
# 1. Banco local de testes: crie hero_pet_test no PostgreSQL local
# 2. Neon: crie um branch/projeto separado para testes
#
# Copie para .env.test e ajuste os valores.
# O Jest carrega .env.test automaticamente quando existir.

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=hero_pet_test

# Se usar Neon para testes, use um banco dedicado:
# POSTGRES_HOST=ep-xxx.neon.tech
# POSTGRES_DB=neondb_test
