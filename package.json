{
  "name": "hero-pet",
  "version": "2.10.2",
  "description": "Um Site para eu analisar os Dados da minha empresa Hero-Pet",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && next dev",
    "dev:standalone": "next dev",
    "dev:with-migrations": "npm run services:up && npm run wait-for-postgres && npm run migration:up && next dev",
    "build": "next build",
    "start": "NODE_ENV=production next start",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "eslint .",
    "test": "npm run services:up && jest --runInBand --verbose --detectOpenHandles",
    "test:ci": "jest --runInBand --verbose --detectOpenHandles",
    "test:with-next": "npm run services:up && concurrently -n next,jest --hide next -k -s command-jest \"next dev\" \"jest --runInBand --verbose\"",
    "test:ci:relatorios": "npm run test:ci -- tests/api/v1/relatorios/relatorios-calculos.test.js",
    "test:ci:bot": "HEROPET_API_KEY=bot-test-key ALLOWED_BAIRROS='centro,jardim europa' BOT_DELIVERY_WINDOW='08:00-22:00' npm run test:ci -- tests/api/bot/bot-endpoints.test.js",
    "test:act-debug": "DEBUG_ACT_WARNINGS=1 npm test",
    "test:act-strict": "ACT_STRICT=1 npm test",
    "posttest": "npm run services:stop",
    "test:watch": "jest --watchAll --runInBand --verbose",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "set -a; . ./.env.test; set +a; npm run testdb:up && npm run testdb:wait && npm run testdb:seed && npm run test:ci:relatorios",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "services:prune": "docker system prune -a",
    "migration:create": "node-pg-migrate -m infra/migrations create",
    "migration:up": "node-pg-migrate -m infra/migrations --envPath .env.development up --check-order false",
    "migration:up:prod": "node-pg-migrate -m infra/migrations --envPath .env.production up --check-order false",
    "migration:up:strict": "node-pg-migrate -m infra/migrations --envPath .env.development up",
    "migration:add-produtos-columns": "node infra/scripts/run-add-produtos-columns.js",
    "migration:repair:order": "node infra/scripts/repair-migration-order.js",
    "migration:remove-orphan-test": "node infra/scripts/remove-legacy-test-migration-record.js",
    "migration:up:safe": "npm run migration:repair:order && npm run migration:up",
    "stock:backfill:simplified": "node infra/scripts/backfill-simplified-stock.js",
    "stock:reconcile:report": "node scripts/stock-reconciliation-report.js",
    "apply:devolucao-capital": "node scripts/apply-devolucao-capital-enum.js",
    "fix:user-role": "node scripts/fix-user-role.js",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js",
    "testdb:up": "docker rm -f hero-pet-test-db >/dev/null 2>&1; docker run --name hero-pet-test-db -e POSTGRES_PASSWORD=testpass -e POSTGRES_DB=hero_pet_test -p 5434:5432 -d postgres:14",
    "testdb:wait": "until docker exec hero-pet-test-db pg_isready -U postgres >/dev/null 2>&1; do sleep 1; done",
    "testdb:down": "docker rm -f hero-pet-test-db",
    "testdb:seed": "node tests/utils/seed-test-db.js",
    "import:orders": "node scripts/import-orders.js",
    "switch:dev": "node scripts/switch-env.js development",
    "switch:prod": "node scripts/switch-env.js production",
    "lint:forms": "node scripts/check-large-forms.js",
    "lint:components": "node scripts/check-large-components.js",
    "lint:hooks": "node scripts/check-large-hooks.js",
    "bot:dev": "npm --prefix bot run dev",
    "bot:test": "npm --prefix bot run test",
    "bot:typecheck": "npm --prefix bot run typecheck"
  },
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "async-retry": "^1.3.3",
    "bcryptjs": "^3.0.3",
    "concurrently": "^9.2.1",
    "cross-fetch": "^4.0.0",
    "dotenv": "^17.2.2",
    "dotenv-expand": "^12.0.3",
    "eslint-config-next": "^15.5.7",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.12",
    "html2canvas": "^1.4.1",
    "lucide-react": "^0.544.0",
    "next": "^15.5.7",
    "next-auth": "^5.0.0-beta.30",
    "node-pg-migrate": "^6.2.2",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.8.0",
    "sonner": "^2.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.13",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "axios": "^1.11.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.1.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
