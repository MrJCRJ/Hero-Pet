# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=hero_pet
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/hero_pet

# NextAuth (obrigatorio; gere com: npx auth secret)
AUTH_SECRET=uma-chave-secreta-aleatoria-min-32-chars

# Migrations
MIGRATIONS_AUTO_APPLY=1

# Redis (usado para historico de mensagens do bot e cache ViaCEP)
REDIS_URL=redis://localhost:6379
# Alternativa individual:
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Bot WhatsApp
HEROPET_API_KEY=sua-chave-api-aqui
ALLOWED_BAIRROS=centro,jardim europa
DELIVERY_START_TIME=08:00
DELIVERY_END_TIME=22:00

# ViaCEP
VIACEP_TIMEOUT=3000

# Bot service (opcional, para healthcheck HTTP direto)
# BOT_SERVICE_URL=http://localhost:3001

# Estoque
# USE_SIMPLIFIED_STOCK=1
# DUAL_WRITE_STOCK=1

# NF-e: use "test" para simular emissao em desenvolvimento
# NFE_PROVIDER=test
